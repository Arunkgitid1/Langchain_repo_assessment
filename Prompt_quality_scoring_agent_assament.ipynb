import os
from langchain_google_genai import ChatGoogleGenerativeAI
from langchain_core.prompts import PromptTemplate
from langchain_core.output_parsers import StrOutputParser
from google.colab import userdata
# get gemini api key
os.environ["GOOGLE_API_KEY"] = userdata.get('GEMINI_API_KEY')
# initialize the model
llm = (ChatGoogleGenerativeAI(model="gemini-2.5-flash")
)
template = """
You are an expert prompt engineering evaluator. Evaluate the following prompt based on these criteria (0-10):
1. Clarity
2. Specificity
3. Context
4. Output Constraints
5. Persona Defined

Prompt to evaluate: "{user_prompt}"

Return your response in this plain text format:
PROMPT EVALUATION REPORT
------------------------
SCORES:
- Clarity: [Score]/10
- Specificity: [Score]/10
- Context: [Score]/10
- Output Constraints: [Score]/10
- Persona: [Score]/10

FINAL AVERAGE SCORE: [Average]

EXPLANATION:
[Your brief explanation here]

SUGGESTIONS FOR IMPROVEMENT:
1. [Suggestion 1]
2. [Suggestion 2]
"""

scoring_prompt = PromptTemplate(
    input_variables=["user_prompt"],
    template=template
)

# Chain using StrOutputParser for plain text
scoring_chain = scoring_prompt | llm | StrOutputParser()

def evaluate_prompt(prompt_text: str):
    return scoring_chain.invoke({"user_prompt": prompt_text})

if __name__ == "__main__":
    sample_prompt = "you are traval assiatent, we need to plan a 10 trip to  newyork and provide best hotels deals and flight deal which food we need to eat in newyork and what are place we visit during trip  ."
    result = evaluate_prompt(sample_prompt)
    print(result)
